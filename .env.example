# ── VNPT Smartbot (Dev 2 — NLP/Triage) ───────────────────────────────────────
# Endpoint chính thức theo tài liệu tích hợp
SMARTBOT_API_URL=https://assistant-stream.vnpt.vn/v1/conversation

# 3 thông tin xác thực — lấy từ ban tổ chức hackathon
SMARTBOT_ACCESS_TOKEN=your_access_token_here
SMARTBOT_TOKEN_ID=your_token_id_here
SMARTBOT_TOKEN_KEY=your_token_key_here

# Bot ID — lấy từ platform Smartbot (dạng UUID: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
SMARTBOT_BOT_ID=your_bot_id_here

# ── VNPT SmartVoice (TTS/STT) ────────────────────────────────────────────────
VNPT_VOICE_TTS_URL=https://api.idg.vnpt.vn/tts-service/...
VNPT_VOICE_STT_URL=https://api.idg.vnpt.vn/stt-service/...
VNPT_VOICE_TOKEN_ID=your_tts_token_id
VNPT_VOICE_TOKEN_KEY=your_tts_token_key
VNPT_VOICE_STT_TOKEN_ID=your_stt_token_id
VNPT_VOICE_STT_TOKEN_KEY=your_stt_token_key
VNPT_VOICE_ACCESS_TOKEN=your_bearer_access_token

# ── Database ─────────────────────────────────────────────────────────────────
# Local để mặc định. Khi deploy có persistent disk: DB_PATH=/var/data/cardiocare.db
DB_PATH=cardiocare.db

# ── Telephony: Twilio (gọi điện thật) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# URL public của server (Twilio gọi webhook ghi âm về). Local: ngrok. Deploy: URL Render/Railway.
PUBLIC_BASE_URL=https://your-app.onrender.com
# Bật/tắt bộ lập lịch tự động gọi theo giờ
CALL_SCHEDULER_ENABLED=true

# ── Telegram (báo người thân khi RED — khả thi ngay, miễn phí) ───────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...      # từ @BotFather
TELEGRAM_CHAT_ID=123456789                # chat_id người thân/điều dưỡng

# ── VNPT SmartUX (đo trải nghiệm người dùng trên web — tuỳ chọn) ─────────────
# app_key: tạo dự án Website tại https://console-smartux.vnpt.vn (tab Tích hợp).
# Để TRỐNG = tắt (web vẫn chạy, chỉ dùng lớp thu thập nội bộ /ux/events).
SMARTUX_APP_KEY=
SMARTUX_URL=https://smartux.icenter.ai
SMARTUX_SDK_PATH=/sdk/web/core-track.js

# ── Zalo ZNS (production, tuỳ chọn) ──────────────────────────────────────────
ZALO_OA_ACCESS_TOKEN=
ZALO_ZNS_TEMPLATE_ID=

# ── Email cảnh báo (tuỳ chọn) ────────────────────────────────────────────────
ALERT_EMAIL_FROM=cardiocare@example.com
ALERT_EMAIL_TO=nurse@hospital.vn
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=your_app_password
